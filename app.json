{
  "expo": {
    "name": "galetiki",
    "slug": "galerialocal",
    "version": "1.5.1",
    "icon": "./galeryapp.png",
    "scheme": "galerialocal",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.galerialocal"
    },
    "android": {
      "icon": "./galeryapp.png",
      "package": "com.anonymous.galerialocal",
      "adaptiveIcon": {
        "foregroundImage": "./galeryapp.png",
        "backgroundColor": "#FFF4E3"
      },
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.MANAGE_MEDIA"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-media-library",
        {
          "photosPermission": "Permitir acceso a fotos.",
          "saveToLibraryPermission": "Permitir guardar fotos.",
          "granularPermissions": [
            "photo",
            "video"
          ],
          "isAccessMediaLocationEnabled": true
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "734f5798-8ae0-42e1-9335-1c6e409edfd0"
      }
    }
  }
}
